diff --git a/net/src/render/brain_swap.rs b/net/src/render/brain_swap.rs
new file mode 100644
index 0000000..122edbd
--- /dev/null
+++ b/net/src/render/brain_swap.rs
@@ -0,0 +1,40 @@
+//! The GCR brain-swap button (rl#232): cycle which trained brain drives each NN crab,
+//! live, through the ONE swap path ([`crab_world::play::cycle_brain`]) the demo also
+//! uses. Sally's brain selection stays where Sally is simulated — the solo/host peer;
+//! a remote-adopt client renders whatever the host drives (its label arrives on the
+//! articulation wire), so its button is a no-op by design, not a second code path.
+
+use bevy::prelude::*;
+
+use crate::controls::{Action, GcrControls};
+use crate::external_crab::{CrabBrainDirs, CrabPolicies};
+
+use super::driver::GameState;
+
+pub(super) fn swap_brain(
+    keys: Res<ButtonInput<KeyCode>>,
+    pads: Query<&Gamepad>,
+    state: Option<NonSend<GameState>>,
+    policies: Option<NonSendMut<CrabPolicies>>,
+    dirs: Option<Res<CrabBrainDirs>>,
+) {
+    if !crab_world::controls::just_pressed::<GcrControls>(Action::SwapBrain, &keys, &pads) {
+        return;
+    }
+    let Some(state) = state else {
+        return;
+    };
+    if state.coord.is_remote_client() {
+        info!("brain swap: this peer adopts the host's Sally — only the host swaps brains");
+        return;
+    }
+    let (Some(mut policies), Some(dirs)) = (policies, dirs) else {
+        return;
+    };
+    // Every bridged crab cycles within its OWN roster (its boot dir + that dir's brain
+    // subdirs) — with one crab this is the latest↔keep-best toggle; the swapped label
+    // reaches every peer through `publish_brain_labels` and the articulation wire.
+    for (policy, root) in policies.0.iter_mut().zip(&dirs.0) {
+        crab_world::play::cycle_brain(policy, root);
+    }
+}
