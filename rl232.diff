+/// The roster name of the primary checkpoint dir itself — the trainer's live/deployed
+/// weights, as opposed to a named subdir like keep-best's `best/`.
+pub const PRIMARY_BRAIN_SLOT: &str = "latest";
+
+/// The swap list rooted at one primary checkpoint dir: the dir itself
+/// ([`PRIMARY_BRAIN_SLOT`]) plus every direct subdirectory holding a `brain.bin`, named
+/// by its dir name and sorted. Data-driven by construction (rl#232): keep-best's `best/`
+/// joins because it is such a subdir, and dropping in more dirs (or symlinks — another
+/// run's ckpt, another architecture) extends the cycle with no code change; each brain's
+/// arch comes from its own envelope at load time.
+pub fn brain_slots(primary: &Path) -> Vec<(String, PathBuf)> {
+    let mut subs: Vec<(String, PathBuf)> = std::fs::read_dir(primary)
+        .into_iter()
+        .flatten()
+        .flatten()
+        .filter_map(|entry| {
+            let dir = entry.path();
+            (dir.is_dir() && CheckpointDir::new(&dir).brain_file().is_file())
+                .then(|| (entry.file_name().to_string_lossy().into_owned(), dir))
+        })
+        .collect();
+    subs.sort();
+    let mut slots = vec![(PRIMARY_BRAIN_SLOT.to_string(), primary.to_owned())];
+    slots.append(&mut subs);
+    slots
+}
+
+/// Swap `policy` to the next loadable brain in the roster under `primary` — THE one
+/// brain-swap code path (rl#232): the demo's button and the GCR host's button both call
+/// this, so the two surfaces can't drift. Re-enumerates the roster per press (a `best/`
+/// promoted since boot, or a run dir dropped in, joins without a restart), skips slots
+/// that refuse to load (each refusal already logged loudly), and returns the slot name it
+/// switched to — `None` when there is nothing to swap to or every other slot refused.
+pub fn cycle_brain(policy: &mut Policy, primary: &Path) -> Option<String> {
+    let slots = brain_slots(primary);
+    if slots.len() < 2 {
+        info!(
+            "brain swap: only one brain under {} — nothing to swap to",
+            primary.display()
+        );
+        return None;
+    }
+    let current = slots
+        .iter()
+        .position(|(_, d)| *d == policy.dir)
+        .unwrap_or(0);
+    for step in 1..slots.len() {
+        let (slot, dir) = &slots[(current + step) % slots.len()];
+        if policy.switch_dir(slot, dir) {
+            return Some(slot.clone());
+        }
+    }
+    None
+}
