+/// to publish (`rl-train eval --min-progress`). Since bddap/rl#239 the eval's headline
+/// is the MIN over an 8-bearing compass, so this gates the policy's WORST bearing.
+/// Recalibrated 2026-07-09 on that metric: the collapsed mlp512x3-s2 brain class
+/// measures ~0.12 m at its BEST bearing (+X) — its worst is at or below that — while
+/// the three live journey checkpoints measure 0.99–2.47 m min-over-bearings. 0.3 sits
+/// ~2.5× above the collapse class while letting the live training journey (owner
+/// directive: the TV streams it, wobbles included) keep publishing.
+const MIN_EVAL_PROGRESS_M: f32 = 0.3;
 
 /// Refuse to publish a checkpoint whose POLICY is dead — it loads and fits the rig
 /// ([`verify_checkpoint_rig`]) yet never drives the crab toward the chase ball. The
diff --git a/rl-eval-monitor/rl-eval-monitor.sh b/rl-eval-monitor/rl-eval-monitor.sh
index 59c8482..38ffeb2 100644
--- a/rl-eval-monitor/rl-eval-monitor.sh
+++ b/rl-eval-monitor/rl-eval-monitor.sh
@@ -86,23 +86,40 @@ eval_run() {
   printf '{"ts":%s,"ticks":%s,"progress_m":%s,"total_torque":%s,"target_m":%s,"reached":%s}\n' \
     "$(date -u +%s)" "$ticks" "$progress_m" "$total_torque" "$target_m" "$reached" \
     >> "$curve"
-  log "[$run] recorded tick=$ticks progress_m=$progress_m total_torque=$total_torque reached=$reached"
+  # The bearing profile (bddap/rl#239) prints on EVAL_RESULT_BEARING lines; keep it in
+  # the op log so an anisotropic dip on the curve is diagnosable without a re-run.
+  local profile
+  profile="$(printf '%s\n' "$out" | sed -nE 's/^EVAL_RESULT_BEARING deg=([0-9]+) progress_m=([0-9.]+).*/\1°=\2/p' | paste -sd' ' -)"
+  log "[$run] recorded tick=$ticks progress_m=$progress_m (min over bearings, worst_deg=$(field worst_deg)) total_torque=$total_torque reached=$reached | $profile"
 }
 
 # Sweep the run dirs (same definitional rule as daily-email's de_runs: direct child with
 # run-train.sh; whole-run backups therefore go under $RUNS_ROOT/archive/, never a direct
 # child, or they'd register as a live run and draw a frozen, lying series). Names are
 # validated because they cross the run=file protocol into plot-curve.js — an unsafe name
-# is skipped LOUDLY. One run's fault never blocks the others' samples; it does fail the
-# unit at the end so the journal (and the fleet-error scan) sees it.
-runs=(); faults=0
+# is skipped LOUDLY.
+#
+# Since bddap/rl#239 the eval sweeps an 8-bearing compass (~2 min wall); evaluating EVERY
+# run every tick would blow the unit's 5-min TimeoutStartSec, so each tick evals exactly
+# ONE run — the one whose curve file is stalest (a missing curve is stalest of all) — and
+# re-plots them all. Per-run cadence = tick interval × live runs (~15 min for 3), fine
+# for a curve spanning days.
+valid=(); faults=0; pick=""; pick_ckpt=""; pick_age=0
 for d in "$RUNS_ROOT"/*/; do
   [ -f "$d/run-train.sh" ] || continue
   run="$(basename "$d")"
   case "$run" in
     *[!A-Za-z0-9._-]*) log "SKIPPING run dir with unsafe name: $run"; faults=$((faults + 1)); continue ;;
   esac
-  eval_run "$run" "${d}ckpt" || faults=$((faults + 1))
+  valid+=("$run")
+  age="$(stat -c %Y "$EVAL_DIR/curve-$run.jsonl" 2>/dev/null || echo 0)"
+  if [ -z "$pick" ] || [ "$age" -lt "$pick_age" ]; then pick="$run"; pick_ckpt="${d}ckpt"; pick_age="$age"; fi
+done
+if [ -n "$pick" ]; then
+  eval_run "$pick" "$pick_ckpt" || faults=$((faults + 1))
+fi
+runs=()
+for run in "${valid[@]}"; do
   [ -s "$EVAL_DIR/curve-$run.jsonl" ] && runs+=("$run=$EVAL_DIR/curve-$run.jsonl")
 done
 [ ${#runs[@]} -gt 0 ] || { log "no run curves yet under $RUNS_ROOT — nothing to plot"; exit $((faults > 0 ? 1 : 0)); }
